{
  "name": "audit-assistant",
  "displayName": "Audit Assistant",
  "description": "LLM-assisted multi-language code security auditing: project structure tree, per-file summary & vulnerability triage, source/sink marking and call-chain verification. Results are stored in .audit/ and shared with the team.",
  "version": "0.1.0",
  "publisher": "audit-team",
  "private": true,
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "auditAssistant",
          "title": "Audit Assistant",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "auditAssistant": [
        {
          "id": "auditFileAnalysis",
          "name": "File Analysis",
          "icon": "media/icon.svg"
        },
        {
          "id": "auditSourceSink",
          "name": "Source / Sink",
          "icon": "media/icon.svg"
        },
        {
          "id": "auditFindings",
          "name": "Call Chains",
          "icon": "media/icon.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "auditFileAnalysis",
        "contents": "Open a code file, then click below to analyze it.\n[Analyze Current File](command:auditAssistant.analyzeCurrentFile)\nFirst time? Configure the LLM endpoint:\n[Set API Key](command:auditAssistant.setApiKey)"
      },
      {
        "view": "auditSourceSink",
        "contents": "No source/sink marks yet.\n[Scan Source/Sink Candidates](command:auditAssistant.scanTaint)\nOr right-click in the editor and choose \"Mark as Source/Sink\" to mark manually."
      },
      {
        "view": "auditFindings",
        "contents": "No call-chain findings yet.\nClick \"Verify Call Chain\" on a Sink item in the \"Source / Sink\" view, or on the CodeLens above a Sink line."
      }
    ],
    "commands": [
      {
        "command": "auditAssistant.setApiKey",
        "title": "Set LLM API Key",
        "category": "Audit"
      },
      {
        "command": "auditAssistant.indexWorkspace",
        "title": "Index Workspace",
        "category": "Audit"
      },
      {
        "command": "auditAssistant.analyzeCurrentFile",
        "title": "Analyze Current File",
        "category": "Audit",
        "icon": "$(sparkle)"
      },
      {
        "command": "auditAssistant.refreshAnalysisView",
        "title": "Refresh",
        "category": "Audit",
        "icon": "$(refresh)"
      },
      {
        "command": "auditAssistant.generateArchitecture",
        "title": "Generate Structure Tree",
        "category": "Audit"
      },
      {
        "command": "auditAssistant.showArchitecture",
        "title": "Show Structure Tree",
        "category": "Audit"
      },
      {
        "command": "auditAssistant.openIndexCache",
        "title": "Reveal Index Cache Location",
        "category": "Audit"
      },
      {
        "command": "auditAssistant.scanTaint",
        "title": "Scan Source/Sink Candidates",
        "category": "Audit",
        "icon": "$(search)"
      },
      {
        "command": "auditAssistant.markAsSource",
        "title": "Mark as Source",
        "category": "Audit"
      },
      {
        "command": "auditAssistant.markAsSink",
        "title": "Mark as Sink",
        "category": "Audit"
      },
      {
        "command": "auditAssistant.confirmMark",
        "title": "Confirm Mark",
        "category": "Audit",
        "icon": "$(check)"
      },
      {
        "command": "auditAssistant.excludeMark",
        "title": "Exclude Mark",
        "category": "Audit",
        "icon": "$(circle-slash)"
      },
      {
        "command": "auditAssistant.restoreMark",
        "title": "Restore to Candidate",
        "category": "Audit",
        "icon": "$(history)"
      },
      {
        "command": "auditAssistant.deleteMark",
        "title": "Delete Mark",
        "category": "Audit",
        "icon": "$(trash)"
      },
      {
        "command": "auditAssistant.refreshSourceSink",
        "title": "Refresh",
        "category": "Audit",
        "icon": "$(refresh)"
      },
      {
        "command": "auditAssistant.verifyChain",
        "title": "Verify Call Chain",
        "category": "Audit",
        "icon": "$(git-compare)"
      },
      {
        "command": "auditAssistant.deleteFinding",
        "title": "Delete Finding",
        "category": "Audit",
        "icon": "$(trash)"
      },
      {
        "command": "auditAssistant.refreshFindings",
        "title": "Refresh",
        "category": "Audit",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "auditAssistant.analyzeCurrentFile",
          "group": "auditAssistant@1"
        },
        {
          "command": "auditAssistant.markAsSource",
          "when": "editorTextFocus",
          "group": "auditAssistant@2"
        },
        {
          "command": "auditAssistant.markAsSink",
          "when": "editorTextFocus",
          "group": "auditAssistant@3"
        }
      ],
      "view/title": [
        {
          "command": "auditAssistant.analyzeCurrentFile",
          "when": "view == auditFileAnalysis",
          "group": "navigation@1"
        },
        {
          "command": "auditAssistant.refreshAnalysisView",
          "when": "view == auditFileAnalysis",
          "group": "navigation@2"
        },
        {
          "command": "auditAssistant.scanTaint",
          "when": "view == auditSourceSink",
          "group": "navigation@1"
        },
        {
          "command": "auditAssistant.refreshSourceSink",
          "when": "view == auditSourceSink",
          "group": "navigation@2"
        },
        {
          "command": "auditAssistant.refreshFindings",
          "when": "view == auditFindings",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "auditAssistant.verifyChain",
          "when": "view == auditSourceSink && viewItem =~ /auditMark\\.sink\\.(candidate|confirmed)/",
          "group": "inline@0"
        },
        {
          "command": "auditAssistant.confirmMark",
          "when": "view == auditSourceSink && viewItem =~ /auditMark\\.(source|sink)\\.candidate/",
          "group": "inline@1"
        },
        {
          "command": "auditAssistant.excludeMark",
          "when": "view == auditSourceSink && viewItem =~ /auditMark\\.(source|sink)\\.candidate/",
          "group": "inline@2"
        },
        {
          "command": "auditAssistant.restoreMark",
          "when": "view == auditSourceSink && viewItem =~ /auditMark\\.(source|sink)\\.(confirmed|excluded)/",
          "group": "inline@1"
        },
        {
          "command": "auditAssistant.deleteMark",
          "when": "view == auditSourceSink && viewItem =~ /auditMark/",
          "group": "inline@9"
        },
        {
          "command": "auditAssistant.deleteFinding",
          "when": "view == auditFindings && viewItem == auditFinding",
          "group": "inline@9"
        }
      ]
    },
    "configuration": {
      "title": "Audit Assistant",
      "properties": {
        "auditAssistant.llm.provider": {
          "type": "string",
          "enum": [
            "openai",
            "opencode"
          ],
          "enumDescriptions": [
            "OpenAI-compatible endpoint (vLLM / Ollama / OneAPI / cloud providers)",
            "opencode serve session-based API (requires a running `opencode serve`)"
          ],
          "default": "openai",
          "description": "LLM backend type. openai = OpenAI-compatible /chat/completions; opencode = opencode serve session-based API."
        },
        "auditAssistant.llm.baseUrl": {
          "type": "string",
          "default": "http://localhost:11434/v1",
          "description": "Endpoint base URL. openai: e.g. http://host:8000/v1; opencode: e.g. http://127.0.0.1:4096 (when provider is opencode and this is left at the default, it auto-switches to that address). Auth credentials are stored in VSCode SecretStorage via the \"Audit: Set LLM API Key\" command and never written to settings."
        },
        "auditAssistant.llm.model": {
          "type": "string",
          "default": "",
          "description": "openai: model name (passed as `model` to /chat/completions). opencode: providerID/modelID, e.g. anthropic/claude-3-5-sonnet-20241022."
        },
        "auditAssistant.llm.opencode.agent": {
          "type": "string",
          "default": "",
          "description": "(opencode only) Optional agent name; leave empty to use the default agent."
        },
        "auditAssistant.llm.temperature": {
          "type": "number",
          "default": 0.2,
          "description": "Sampling temperature. A low value is recommended for auditing."
        },
        "auditAssistant.llm.maxTokens": {
          "type": "number",
          "default": 4096,
          "description": "Maximum number of tokens per response."
        },
        "auditAssistant.llm.timeoutMs": {
          "type": "number",
          "default": 180000,
          "description": "Per-request timeout in milliseconds."
        },
        "auditAssistant.analysis.outputLanguage": {
          "type": "string",
          "enum": [
            "en",
            "zh",
            "ja"
          ],
          "enumDescriptions": [
            "English",
            "Simplified Chinese (简体中文)",
            "Japanese (日本語)"
          ],
          "default": "en",
          "description": "Language for analysis results produced by the LLM."
        },
        "auditAssistant.index.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**",
            "**/.git/**",
            "**/dist/**",
            "**/build/**",
            "**/out/**",
            "**/target/**",
            "**/vendor/**",
            "**/.audit/**",
            "**/*.min.js"
          ],
          "description": "Glob patterns to exclude during indexing."
        },
        "auditAssistant.author": {
          "type": "string",
          "default": "",
          "description": "Auditor name recorded on marks/findings. Leave empty to use the system username."
        }
      }
    }
  },
  "scripts": {
    "copy-wasm": "node scripts/copy-wasm.js",
    "build": "npm run copy-wasm && node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "compile-test": "tsc -p tsconfig.test.json",
    "test": "npm run copy-wasm && npm run compile-test && node --test \"test/*.test.cjs\" && node test/bundle-smoke.cjs",
    "vscode:prepublish": "npm run build -- --production"
  },
  "dependencies": {
    "web-tree-sitter": "^0.25.6"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.24.0",
    "tree-sitter-wasms": "^0.1.12",
    "typescript": "^5.6.0"
  }
}
